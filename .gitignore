# ============================================================
# Qt / C++ 项目忽略规则
# ============================================================

# 构建目录
build/
Build/

# 部署目录（包含 Qt 运行时 DLL，体积巨大）
dist/

*.pro.user
*.pro.user.*
moc_*.cpp
qrc_*.cpp
ui_*.h
Makefile
Makefile.*
*.o
*.obj
*.exe
*.dll
*.lib
*.a
*.so
*.dylib

# IDE 文件
.vscode/
.idea/
*.swp
*.swo
*~
.cproject
.project
.settings/

# Qt Creator
*.autosave

# 数据库文件（用户数据，不提交）
*.db
*.db-journal
*.db-wal
*.db-shm

# 配置文件（用户自定义）
config.json

# 录制/媒体文件
records/
*.mp4
*.avi
*.flv
*.mkv

# 日志
*.log
/logs/

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 文档生成
/doc/
*.pdf
